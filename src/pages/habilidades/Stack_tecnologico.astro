---
import Dodecahedron from "@habilidades/Dodecahedron_habilidades";
import Tecnologias from "@habilidades/Tecnologias.astro";
import { HiWrenchScrewdriver } from "react-icons/hi2";
---

<section class="mx-auto max-w-7xl px-6 pt-6">
  <div class="rounded-2xl border border-cyan-400/25 bg-slate-900/40 p-6 shadow-[0_0_60px_rgba(56,189,248,0.12)]">
    <h2 class="mb-6 flex items-center gap-3 text-xl font-semibold sm:text-2xl">
      <HiWrenchScrewdriver className="h-6 w-6 text-cyan-300" aria-label="Stack" />
      <span>Stack Tecnologico</span>
    </h2>

    <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-2">
      <div class="flex items-center justify-center">
        <div class="origin-center scale-90 sm:scale-100 md:scale-110">
          <Dodecahedron client:load />
        </div>
      </div>

      <div>
        <Tecnologias />
      </div>
    </div>
  </div>
</section>
