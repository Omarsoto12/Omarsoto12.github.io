---
import { HiFolderOpen } from "react-icons/hi2";
import { ProyectosGrid } from "@/mis_proyectos/ProyectosGrid";
---

<section class="mx-auto max-w-[90rem] px-6 pt-8">
  <div class="rounded-2xl border border-cyan-400/25 bg-slate-900/40 p-6 shadow-[0_0_60px_rgba(56,189,248,0.12)] sm:p-8">
    <h2 class="flex items-center gap-3 text-2xl font-bold sm:text-3xl">
      <HiFolderOpen className="h-6 w-6 text-cyan-300" aria-label="Mis proyectos" />
      <span>Mis Proyectos</span>
    </h2>

    <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-300 sm:text-base">
        Estos proyectos reflejan mi capacidad para resolver problemas reales, mejorar procesos y construir soluciones
        innovadoras. Cada uno es un ejemplo concreto de mi enfoque práctico y orientado a resultados.
    </p>

    <div class="mt-7">
      <ProyectosGrid client:load />
    </div>
  </div>
</section>
